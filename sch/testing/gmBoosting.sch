C {simulator_commands_shown.sym} -2080 410 0 0 {
name=Libs_Ngspice2
simulator=ngspice
only_toplevel=false
value="
.include gmBoosting.save
.lib cornerMOSlv.lib mos_tt
.lib cornerRES.lib res_typ
.temp 65
.control
save all
op
write gmBoosting.raw


ac dec 1k 1 10G
let Av = db((v(Vo1)-v(Vo2)))
meas ac UGBW WHEN Av=0
let phase_vec = 180/pi*cph(v(Vo1)-v(Vo2))

meas ac phase FIND phase_vec WHEN frequency=UGBW 
let PM = phase+180
print PM

plot Av
plot phase_vec



.endc
"
      }
